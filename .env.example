# Environment Variables for Study With Sutirtha

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=your_sanity_api_token

# Site URL
NEXT_PUBLIC_SITE_URL=https://studywithsutirtha.com

# Contact
NEXT_PUBLIC_CONTACT_EMAIL=info@studywithsutirtha.com
NEXT_PUBLIC_CONTACT_PHONE=+91-9064077914
NEXT_PUBLIC_WHATSAPP_NUMBER=+919064077914

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Google Sheets Webapp Integration
GOOGLE_SHEET_WEBAPP_URL=your_google_apps_script_webapp_url

# Email (Resend or NodeMailer)
RESEND_API_KEY=your_resend_api_key
